#!/usr/bin/env sh
set -eu

args="$*"

wait() {
  sleep 0.8
}

case " $args " in
  *" --web-search "*)
    printf '%s\n' 'Searching web: latest Go release changes'
    wait
    printf '\n%s\n\n' '## Current answer'
    printf '%s\n' \
      '- Found recent release notes and compatibility updates.' \
      '- Summarized the changes instead of relying on stale training data.' \
      '- Included source links in the final answer when available.'
    ;;
  *" --review "*)
    printf '%s\n' 'Reading file: README.md'
    wait
    printf '%s\n\n' 'Writing file: docs/cli-notes.md'
    printf '%s\n' 'Review: Write docs/cli-notes.md (642 bytes)'
    printf '%s' '[Y] Approve  [N] Deny  [A] Always allow: fs_write_file  [Ctrl+C] Cancel '
    IFS= read -r answer || answer=
    case "$answer" in
      [Nn]*)
        printf '\n%s\n' 'Execution denied.'
        exit 1
        ;;
    esac
    printf '\n%s\n' 'Wrote docs/cli-notes.md'
    printf '%s\n' 'Added a concise command-line usage section based on README.md.'
    ;;
  *" --reasoning "*|*" --debug "*)
    printf '%s\n' '[debug] API request - model=gpt-5 api=openai'
    printf '%s\n' '[debug] Tools: 3 total tools'
    printf '%s\n' 'Deep reasoning...'
    wait
    printf '%s\n' 'Thinking: compare risk, test coverage, and user-visible behavior'
    printf '%s\n\n' 'Searching files: ReviewMode in .'
    printf '%s\n' 'Recommendation: use --review mutable for normal coding, --review always for audits, and --review never only in trusted automation.'
    ;;
  *" --minimal "*)
    wait
    printf '%s\n' \
      'README.md' \
      'config.go' \
      'examples.go' \
      'internal/tools/builtin.go' \
      'review.go'
    ;;
  *" --clipboard-image "*|*" --stdin-image "*|*" --image "*|*" -i "*)
    printf '%s\n' 'Reading image: examples/gifs/mods-product.png'
    wait
    printf '\n%s\n\n' 'The image shows the Mods product art and wordmark.'
    printf '%s\n' 'Suggested alt text:'
    printf '%s\n' \
      '1. Mention that Mods is AI for the command line.' \
      '2. Keep the description short enough for README usage.' \
      '3. Avoid describing decorative terminal details unless they matter.'
    ;;
  *" --list "*|*" -l "*)
    printf '%s\n' \
      '8a0d428  release notes draft' \
      '4ef8c12  summarize cache tests' \
      'b94107d  docs usage guide'
    ;;
  *" --show "*|*" -s "*)
    printf '%s\n' '# release notes draft'
    printf '\n%s\n\n' 'User: summarize the latest changes in this fork'
    printf '%s\n' 'Assistant: Added web search, image input, built-in tools with review, reasoning controls, and refreshed model support.'
    ;;
  *" -M "*|*" --ask-model "*)
    printf '%s\n' '? Select a model'
    printf '%s\n' '  openai/gpt-5'
    printf '%s\n' '  anthropic/claude-sonnet-4'
    printf '%s\n' '> groq/llama-3.3-70b-versatile'
    wait
    printf '\n%s\n\n' 'Using groq/llama-3.3-70b-versatile'
    printf '%s\n' 'Hello. Mods can route the same prompt through any configured provider.'
    ;;
  *)
    wait
    printf '%s\n' '## Charmbracelet repositories'
    printf '\n%s\n' 'Top picks: bubbletea, lipgloss, gum, and vhs.'
    printf '%s\n' 'Mods turns command output into a concise, formatted summary that is easy to read in the terminal.'
    ;;
esac
